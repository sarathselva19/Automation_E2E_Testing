<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >
<suite name="Combined Automation Framework" parallel="false" verbose="2">
    <test name="Login Tests">
        <classes>
            <class name="com.combined.automation.stepDefinitions.UI.LoginTest">
                <methods>
                    <include name="login"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="DropDown Tests">
        <classes>
            <class name="com.combined.automation.stepDefinitions.UI.DropDown">
                <methods>
                    <include name="dropDOwn"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="WebTable Tests">
        <classes>
            <class name="com.combined.automation.stepDefinitions.UI.WebTable">
                <methods>
                    <include name="webTable"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Stale Element Tests">
        <classes>
            <class name="com.combined.automation.stepDefinitions.UI.StaleTest">
                <methods>
                    <include name="staleTest"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Shadow Root Element Tests">
        <classes>
            <class name="com.combined.automation.stepDefinitions.UI.ShadowRootElement">
                <methods>
                    <include name="shadowRootHandle"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="App Tests">
        <classes>
            <class name="com.combined.automation.AppTest">
                <methods>
                    <include name="testApp"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>

